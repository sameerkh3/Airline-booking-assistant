# ============================================================
# Airline Booking Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Anthropic ---
# API key for Claude (claude-sonnet-4-6)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Flight Data API ---
# SerpAPI key for Google Flights real data (Phase 2)
# Get yours at: https://serpapi.com/ — 250 free searches/month, no credit card required
SERPAPI_KEY=your_serpapi_key_here
# Set to "true" to use mock flight data instead of the real API (useful for dev/testing)
USE_MOCK_FLIGHTS=false

# --- Custom MCP Email Server ---
# URL of the custom ABA MCP server (mcp-server/server.py)
# Default when running locally: http://localhost:8001/mcp
MCP_SERVER_URL=http://localhost:8001/mcp
# Email address that will send flight result emails
GMAIL_EMAIL=your_gmail_address@gmail.com
# Gmail App Password (generate at https://myaccount.google.com/apppasswords)
# Required if 2FA is enabled — do NOT use your main account password
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# --- CORS ---
# URL of the frontend dev server (Vite default)
FRONTEND_URL=http://localhost:5173
